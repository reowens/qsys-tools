{
  "name": "qsys-tools",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for the qsys family: qsys-qrc (QRC client core), qsys-cli (control CLI), qsys-mcp (MCP server), and qsys-mac tooling.",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "qsys-mac": "tsx packages/qsys-mac/src/bin.ts",
    "build": "pnpm -r build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
