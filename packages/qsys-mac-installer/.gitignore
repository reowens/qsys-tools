# Build/distribution artifacts (regenerated by scripts/package.sh)
dist/
*.dmg

# Python bytecode cache from importing lib/patch-loader-plist.py at build time — must never ride
# into the notarized bundle (A18); package.sh also strips it before xcodegen.
__pycache__/
*.pyc

# macOS Finder cruft
.DS_Store
.gmax.json
