# qsys-mac — headless CLI for the Q-SYS Designer macOS wrapper.
#
# The GUI installer (Install Q-SYS Designer.app) drives the very same provision.sh + emit;
# this exposes them for SSH / scripted use. It's also the most portable base for a future
# Linux port — the command surface (install/remove/status) stays put; only the recipe
# internals behind it would change. Zero QSC bytes.
#
#   qsys-mac install <your Q-SYS Designer Installer*.exe>   provision Wine+Designer, place the app
#   qsys-mac remove                                         uninstall (app + data dir, orphan-safe)
#   qsys-mac status                                         show install state
#   qsys-mac doctor                                         print support diagnostics
#
# It needs the bundled deps (provision.sh, lib/, bin/, cache/, Launcher.app). By default it
# self-locates them as siblings (it lives in the app's Contents/Resources), so run it straight
# from a mounted dmg:
#   "/Volumes/Install Q-SYS Designer/Install Q-SYS Designer.app/Contents/Resources/qsys-mac" install …
# Or point it at any unpacked Resources dir with QSYS_RES=/path/to/Resources.
set -uo pipefail

RES="${QSYS_RES:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"   # the app's Resources dir
DATA_DIR="$HOME/Library/Application Support/Q-SYS Designer"        # == Swift DataDir.root
APP_NAME="Q-SYS Designer.app"                                      # == Emitter.appName
APP_DIRS=("/Applications" "$HOME/Applications")                    # try system, fall back to home
REQUIRED_SCHEMA=2                                                   # == Swift DataDir.requiredRecipeSchema
LOG_FILE="$HOME/Library/Logs/Q-SYS Designer/wine.log"
LEGACY_LOG_FILE="$HOME/Library/Logs/Q-SYS-Designer.log"

say()  { printf '\033[1;36m[qsys]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[qsys] WARN:\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31m[qsys] ERROR:\033[0m %s\n' "$*" >&2; exit 1; }

wine_bin() { printf '%s' "$DATA_DIR/Wine Staging.app/Contents/Resources/wine/bin/wine"; }
ws_bin()   { printf '%s' "$DATA_DIR/Wine Staging.app/Contents/Resources/wine/bin/wineserver"; }
wine_bin_dir() { printf '%s' "$DATA_DIR/Wine Staging.app/Contents/Resources/wine/bin/"; }

# Provisioned == the marker is written AND wine is runnable AND a Designer.exe is in the prefix.
provisioned() {
  [ -f "$DATA_DIR/.provisioned" ] || return 1
  [ -x "$(wine_bin)" ] || return 1
  find "$DATA_DIR/prefix/drive_c" -iname 'Q-Sys Designer.exe' -print -quit 2>/dev/null | grep -q .
}

# Echo the emitted app's path if it exists (system Applications wins over home).
installed_app() {
  local d
  for d in "${APP_DIRS[@]}"; do
    [ -d "$d/$APP_NAME" ] && { printf '%s' "$d/$APP_NAME"; return 0; }
  done
  return 1
}

designer_exe() {
  find "$DATA_DIR/prefix/drive_c" -iname 'Q-Sys Designer.exe' -print -quit 2>/dev/null
}

cmd_install() {
  local exe="${1:-}"
  [ -n "$exe" ] || die "usage: qsys-mac install <path to your Q-SYS Designer Installer*.exe>"
  [ -f "$exe" ] || die "installer not found: $exe"
  [ -f "$RES/provision.sh" ] || die "can't find provision.sh in $RES — set QSYS_RES to the app's Resources dir"
  [ -d "$RES/Launcher.app" ] || die "bundled Launcher.app missing in $RES — run from the installer app's Resources"

  say "Provisioning into $DATA_DIR …"
  # Same env the Swift Provisioner passes: the app's data dir + the bundled (offline,
  # toolchain-free) deps. The @@QSYS:STEP@@/@@QSYS:EXTRACT@@ progress tokens are for the GUI;
  # rewrite STEP to a readable line and drop the EXTRACT spam.
  local rc=0
  WRAP_HOME="$DATA_DIR" \
  CACHE="$RES/cache" \
  QSYS_PREBUILT_APPMENU="$RES/bin/appmenu.dylib" \
  QSYS_PREBUILT_ICONPAD="$RES/bin/iconpad" \
  QSYS_PREPATCHED_LOADER="$RES/bin/wine-loader-prepatched" \
  PATH="$RES/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:/usr/local/bin" \
    /bin/bash "$RES/provision.sh" "$exe" \
      | /usr/bin/sed -e 's/^@@QSYS:STEP \([0-9]*\) \([0-9]*\) \(.*\)@@$/  --> [\1\/\2] \3/' -e '/^@@QSYS:EXTRACT /d' \
    || rc=$?
  [ "$rc" -eq 0 ] || die "provisioning failed (see the [qsys] ERROR above)"

  emit
  say "Done. Launch it from $(installed_app)."
}

# Place the launcher, bake the extracted QSC icon, ad-hoc re-sign — a faithful port of Emit.swift.
emit() {
  local src="$RES/Launcher.app" d dest placed=""
  say "Placing $APP_NAME …"
  for d in "${APP_DIRS[@]}"; do
    dest="$d/$APP_NAME"
    mkdir -p "$d" 2>/dev/null || continue
    rm -rf "$dest" 2>/dev/null || true                 # idempotent reinstall
    if cp -R "$src" "$dest" 2>/dev/null; then placed="$dest"; break; fi
  done
  [ -n "$placed" ] || die "couldn't place $APP_NAME in /Applications or ~/Applications"

  # Icon-in-Resources + ad-hoc re-sign (NOT a custom Finder icon, which sets a FinderInfo xattr
  # that fails codesign --strict on macOS 26). The re-sign drops the Developer-ID seal, but this
  # copy is created locally → no quarantine → Gatekeeper opens it.
  local icon="$DATA_DIR/QSYSDesigner.icns"
  if [ -f "$icon" ]; then
    mkdir -p "$placed/Contents/Resources"
    cp "$icon" "$placed/Contents/Resources/AppIcon.icns"
    codesign --force -s - "$placed" >/dev/null 2>&1 || die "ad-hoc re-sign failed"
  else
    warn "no extracted icon at $icon — keeping the launcher's generic icon (cosmetic)"
  fi
  xattr -dr com.apple.quarantine "$placed" 2>/dev/null || true
  [ "$placed" = "$HOME/Applications/$APP_NAME" ] && warn "placed in ~/Applications (no admin access to /Applications)"
  return 0
}

cmd_remove() {
  if ! installed_app >/dev/null 2>&1 && [ ! -d "$DATA_DIR" ]; then say "nothing installed."; return 0; fi
  # Stop Designer/Wine bound to our prefix BEFORE unlinking, else wineserver orphans off the
  # deleted tree (matches Uninstaller.remove): graceful server shutdown, then TERM → grace → KILL.
  [ -x "$(ws_bin)" ] && WINEPREFIX="$DATA_DIR/prefix" "$(ws_bin)" -k >/dev/null 2>&1
  if [ -d "$(wine_bin_dir)" ]; then
    pkill -f "$(wine_bin_dir)" 2>/dev/null; sleep 0.5; pkill -9 -f "$(wine_bin_dir)" 2>/dev/null
  fi
  local p any=0
  for p in "$DATA_DIR" "/Applications/$APP_NAME" "$HOME/Applications/$APP_NAME"; do
    if [ -e "$p" ]; then
      if rm -rf "$p"; then say "removed: $p"; any=1; else warn "couldn't remove: $p"; fi
    fi
  done
  [ "$any" -eq 1 ] && say "Q-SYS Designer removed." || say "nothing to remove."
}

cmd_status() {
  if provisioned; then
    printf 'provisioned : yes  (%s, %s)\n' "$DATA_DIR" "$(du -sh "$DATA_DIR" 2>/dev/null | cut -f1)"
  else
    printf 'provisioned : no\n'
  fi
  local app
  if app="$(installed_app)"; then printf 'app         : %s\n' "$app"; else printf 'app         : (not placed)\n'; fi
  if [ -d "$(wine_bin_dir)" ] && pgrep -f "$(wine_bin_dir)" >/dev/null 2>&1; then printf 'running     : yes\n'; else printf 'running     : no\n'; fi
}

bool() { [ "$1" = "0" ] && printf 'yes' || printf 'no'; }
yn_exists() { [ -e "$1" ] && printf 'yes' || printf 'no'; }
yn_exec() { [ -x "$1" ] && printf 'yes' || printf 'no'; }
du_size() { du -sh "$1" 2>/dev/null | cut -f1 || printf '-'; }
plist_value() { /usr/libexec/PlistBuddy -c "Print :$2" "$1/Contents/Info.plist" 2>/dev/null || printf 'unknown'; }
verify_codesign() { codesign --verify --deep --strict "$1" >/dev/null 2>&1; bool "$?"; }
verify_staple() { xcrun stapler validate "$1" >/dev/null 2>&1; bool "$?"; }

installer_app_bundle() {
  case "$RES" in
    */Contents/Resources)
      local contents app
      contents="$(cd "$RES/.." 2>/dev/null && pwd)" || return 1
      app="$(cd "$contents/.." 2>/dev/null && pwd)" || return 1
      [ -d "$app" ] || return 1
      printf '%s' "$app"
      ;;
    *) return 1 ;;
  esac
}

rosetta_status() {
  if [ "$(uname -m)" != "arm64" ]; then printf 'not needed'; return 0; fi
  if /usr/bin/arch -x86_64 /usr/bin/true >/dev/null 2>&1; then printf 'installed'; else printf 'missing'; fi
}

first_glob() {
  local found
  while IFS= read -r found; do
    printf '%s' "$found"
    return 0
  done < <(compgen -G "$1")
}

cache_status() {
  local label="$1" pattern="$2" found
  found="$(first_glob "$pattern")"
  if [ -n "$found" ]; then
    printf '  %-22s : yes (%s)\n' "$label" "$(basename "$found")"
  else
    printf '  %-22s : no\n' "$label"
  fi
}

resource_status() {
  local label="$1" file="$2" mode="$3"
  if [ "$mode" = "exec" ]; then
    printf '  %-22s : %s (%s)\n' "$label" "$(yn_exec "$file")" "$file"
  else
    printf '  %-22s : %s (%s)\n' "$label" "$(yn_exists "$file")" "$file"
  fi
}

cmd_doctor() {
  local installer_app app exe schema running
  printf 'qsys-mac doctor\n\n'

  printf 'Host\n'
  printf '  %-22s : %s\n' 'macOS' "$(sw_vers -productVersion 2>/dev/null || printf 'unknown')"
  printf '  %-22s : %s\n' 'architecture' "$(uname -m)"
  printf '  %-22s : %s\n' 'Rosetta 2' "$(rosetta_status)"

  printf '\nInstaller resources\n'
  printf '  %-22s : %s\n' 'Resources dir' "$RES"
  if installer_app="$(installer_app_bundle)"; then
    printf '  %-22s : %s\n' 'Installer app' "$installer_app"
    printf '  %-22s : %s\n' 'Installer version' "$(plist_value "$installer_app" CFBundleShortVersionString)"
    printf '  %-22s : %s\n' 'Installer signature' "$(verify_codesign "$installer_app")"
    printf '  %-22s : %s\n' 'Installer stapled' "$(verify_staple "$installer_app")"
  else
    printf '  %-22s : unknown (QSYS_RES is not inside an app bundle)\n' 'Installer app'
  fi
  resource_status 'qsys-mac helper' "$RES/qsys-mac" exec
  resource_status 'msiinfo' "$RES/bin/msiinfo" exec
  resource_status 'native MSI helper' "$RES/bin/qsys-assemble-msi" exec
  resource_status 'native font helper' "$RES/bin/qsys-rename-font-family" exec
  resource_status 'prepatched loader' "$RES/bin/wine-loader-prepatched" file
  resource_status 'app menu shim' "$RES/bin/appmenu.dylib" file
  cache_status 'Wine cache' "$RES/cache/wine-staging-*.tar.xz"
  cache_status '.NET Desktop cache' "$RES/cache/windowsdesktop-runtime-*-win-x64.exe"
  cache_status 'ASP.NET cache' "$RES/cache/aspnetcore-runtime-*-win-x64.exe"

  printf '\nProvisioned data\n'
  if [ -d "$DATA_DIR" ]; then
    printf '  %-22s : yes (%s, %s)\n' 'Data dir' "$DATA_DIR" "$(du_size "$DATA_DIR")"
  else
    printf '  %-22s : no (%s)\n' 'Data dir' "$DATA_DIR"
  fi
  printf '  %-22s : %s\n' 'Provisioned marker' "$(yn_exists "$DATA_DIR/.provisioned")"
  if [ -f "$DATA_DIR/.qsys-recipe-schema" ]; then
    schema="$(tr -d '[:space:]' <"$DATA_DIR/.qsys-recipe-schema" 2>/dev/null || true)"
    printf '  %-22s : %s (required %s)\n' 'Recipe schema' "${schema:-unknown}" "$REQUIRED_SCHEMA"
  else
    printf '  %-22s : missing (required %s)\n' 'Recipe schema' "$REQUIRED_SCHEMA"
  fi
  printf '  %-22s : %s (%s)\n' 'Wine binary' "$(yn_exec "$(wine_bin)")" "$(wine_bin)"
  exe="$(designer_exe)"
  if [ -n "$exe" ]; then printf '  %-22s : yes (%s)\n' 'Designer.exe' "$exe"; else printf '  %-22s : no\n' 'Designer.exe'; fi
  if provisioned; then printf '  %-22s : yes\n' 'Provisioned'; else printf '  %-22s : no\n' 'Provisioned'; fi

  printf '\nInstalled launcher\n'
  if app="$(installed_app)"; then
    printf '  %-22s : %s\n' 'App path' "$app"
    printf '  %-22s : %s\n' 'App version' "$(plist_value "$app" CFBundleShortVersionString)"
    printf '  %-22s : %s\n' 'App signature' "$(verify_codesign "$app")"
  else
    printf '  %-22s : not placed\n' 'App path'
  fi
  if [ -d "$(wine_bin_dir)" ] && pgrep -f "$(wine_bin_dir)" >/dev/null 2>&1; then running=yes; else running=no; fi
  printf '  %-22s : %s\n' 'Running' "$running"

  printf '\nLogs\n'
  printf '  %-22s : %s (%s)\n' 'Wine log' "$(yn_exists "$LOG_FILE")" "$LOG_FILE"
  printf '  %-22s : %s (%s)\n' 'Legacy debug log' "$(yn_exists "$LEGACY_LOG_FILE")" "$LEGACY_LOG_FILE"
}

case "${1:-}" in
  install)          shift; cmd_install "$@" ;;
  remove|uninstall) cmd_remove ;;
  status)           cmd_status ;;
  doctor)           cmd_doctor ;;
  *)
    cat >&2 <<'EOF'
qsys-mac — Q-SYS Designer macOS wrapper CLI
  qsys-mac install <Q-SYS Designer Installer*.exe>   provision Wine+Designer, place the app
  qsys-mac remove                                    uninstall (app + data dir, orphan-safe)
  qsys-mac status                                    show install state
  qsys-mac doctor                                    print support diagnostics
Run it from the installer app's Contents/Resources, or set QSYS_RES to that dir.
EOF
    exit 2 ;;
esac
